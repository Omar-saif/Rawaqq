# --- Database ---
# PostgreSQL connection string. Vercel Postgres, Neon, and Supabase all work.
DATABASE_URL="postgresql://user:password@host:5432/rawaq"

# --- Auth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Image uploads (banners & product photos) ---
# Create a Blob store in your Vercel project dashboard -> Storage -> Blob.
# The token below is generated automatically for you there.
BLOB_READ_WRITE_TOKEN=""

# --- Payments (optional) ---
# Leave blank to run in demo mode (COD works fully; card checkout lands on a
# placeholder confirmation screen). Fill in once you've picked a gateway
# (Moyasar, HyperPay, or Tap) — see lib/payment.ts for integration notes.
PAYMENT_GATEWAY_SECRET_KEY=""

# --- Seed data (optional, used by `npm run db:seed`) ---
SEED_ADMIN_EMAIL="admin@rawaq.sa"
SEED_ADMIN_PASSWORD="ChangeMe123!"
