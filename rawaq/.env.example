# --- Database ---
# Auto-filled if you add the Neon Postgres integration from the Vercel
# Storage tab — you won't need to touch this manually.
DATABASE_URL="postgresql://user:password@host:5432/rawaq"

# --- Auth ---
# Required. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"
# Optional on Vercel (auto-detected from the request), but safest to set to
# your production domain, e.g. https://rawaq.vercel.app
NEXTAUTH_URL=""

# --- App ---
# Optional — falls back to Vercel's auto-provided URL if left blank.
NEXT_PUBLIC_APP_URL=""

# --- First-time setup ---
# Pick any password-like string. Visit /setup once after your first deploy
# and enter this value to create your admin account — no CLI needed.
SETUP_SECRET="choose-a-one-time-setup-password"

# --- Image uploads (banners & product photos) ---
# Auto-filled if you add the Blob integration from the Vercel Storage tab.
BLOB_READ_WRITE_TOKEN=""

# --- Payments (optional) ---
# Leave blank to run in demo mode (COD works fully; card checkout lands on a
# placeholder confirmation screen). Fill in once you've picked a gateway
# (Moyasar, HyperPay, or Tap) — see lib/payment.ts for integration notes.
PAYMENT_GATEWAY_SECRET_KEY=""

